<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My <%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <%- include('./partials/header') %>
  <h2>Edit <%= title %></h2>

  <form action="<%= route %>/<%= project._id %>/edit" method="POST" enctype="multipart/form-data">
    <label>Project Name:</label>
    <input type="text" name="name" value="<%= project.name %>" required>
  
    <label>Description:</label>
    <textarea name="description" required><%= project.description %></textarea>
  
    <label>GitHub Link:</label>
    <input type="url" name="githubLink" value="<%= project.githubLink %>">
  
    <label>Live Demo:</label>
    <input type="url" name="liveDemo" value="<%= project.liveDemo %>">
    
    <label>Technologies (comma separated):</label>
    <input type="text" name="technologies" value="<%= project.technologies.join(', ') %>">
  
    <label>Current Image:</label><br>
    <% if (project.image) { %>
      <img src="/uploads/<%= project.image %>" alt="Project Image" style="max-width: 200px;"><br>
    <% } else { %>
      <p>No image uploaded.</p>
    <% } %>
  
    <label>Change Image:</label>
    <input type="file" name="image">
  
    <button type="submit">Update Project</button>
  </form>
  
  <%- include('./partials/footer') %>


</body>

</html>