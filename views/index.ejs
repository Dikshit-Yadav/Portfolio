<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>My Portfolio</title>
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body>

    <%- include('./partials/header') %>
    <main>
        <section id="hero">
        <h1>Hi, I'm Dikshit Yadav 👋</h1>
<p>I build modern, scalable web applications using the MERN stack with a focus on performance and user experience.</p>
            <a href="/projects" class="btn primary">🚀 View Projects</a>
        </section>

        <section id="about-summary">
            <h2>About Me</h2>
            <p>
    I specialize in building scalable and dynamic web applications using the MERN stack. I focus on developing efficient backend systems, designing RESTful APIs, and creating seamless user experiences. I am a quick learner and a team-oriented individual, continuously exploring new technologies and improving my skills through real-world projects.
</p>
            <a href="/about" class="btn">📘 More About Me</a>
        </section>

        <section id="projects">
            <h2>Featured Projects</h2>

            <div class="project-grid">
                <% if (projects && projects.length > 0) { %>
                    <% projects.forEach(project => { %>
                        <div class="project-card">
                            <h3><%= project.name %></h3>

                            <% if (project.image) { %>
                                <img src="<%= project.image %>" alt="<%= project.name %>" width="300">
                            <% } else { %>
                                <p><em>No image available.</em></p>
                            <% } %>

                           <p>
  <%= project.description.length > 400 ? project.description.substring(0, 400) + '...' : project.description %>
</p>

                            <p><strong>Technologies:</strong> 
                                <%= project.technologies?.length ? project.technologies.join(", ") : 'N/A' %>
                            </p>

                            <div class="project-links">
                                <% if (project.liveDemo && project.liveDemo.trim()) { %>
                                    <a href="<%= project.liveDemo %>" class="btn btn-success" target="_blank">🌐 Live Demo</a>
                                <% } else { %>
                                    <span class="disabled-link">No Live Demo</span>
                                <% } %>

                                <% if (project.githubLink && project.githubLink.trim()) { %>
                                    <a href="<%= project.githubLink %>" class="btn btn-dark" target="_blank">🐱 GitHub</a>
                                <% } else { %>
                                    <span class="disabled-link">No GitHub Link</span>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p>No projects available.</p>
                <% } %>
            </div>
        </section>

        <section id="cta">
            <h2>Let's Work Together</h2>
            <p>Have a project in mind or want to collaborate? Feel free to reach out!</p>
            <a href="/contact" class="btn primary">📬 Contact Me</a>
        </section>
    </main>

   <%- include('./partials/footer') %>
</body>

</html>
